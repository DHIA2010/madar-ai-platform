{
  "name": "madar",
  "version": "1.0.0",
  "description": "MADAR - AI Marketing Intelligence Platform",
  "author": "MADAR Team",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "build:ci": "TURBOPACK_ROOT=$PWD next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 \"src/components/app/**/*.{ts,tsx}\" \"src/features/**/*.{ts,tsx}\" \"src/{lib,services,providers,constants,types,hooks,store}/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "lint:architecture": "eslint \"src/features/**/*.{ts,tsx}\" \"src/components/app/**/*.{ts,tsx}\"",
    "lint:boundaries": "dependency-cruiser --config .dependency-cruiser.cjs src",
    "lint:routes": "node ./scripts/check-routes.mjs",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "test:identity": "vitest run src/identity-platform/tests",
    "test:identity:coverage": "vitest run --coverage src/identity-platform/tests",
    "typecheck": "tsc --noEmit",
    "identity:dev": "node --import tsx src/identity-platform/server.ts",
    "identity:lint": "eslint --max-warnings=0 \"src/identity-platform/**/*.{ts,tsx}\" \"scripts/validate-identity-migrations.mjs\"",
    "format": "node ./scripts/run-prettier-governed.mjs --write",
    "format:check": "node ./scripts/run-prettier-governed.mjs --check",
    "check:circular": "madge --circular --extensions ts,tsx src",
    "check:deadcode": "knip --reporter compact || true",
    "check:deps": "node ./scripts/check-deps.mjs",
    "check:env": "node ./scripts/validate-env.mjs",
    "test:ci": "npm run test --if-present",
    "identity:install": "npm --prefix identity-platform install",
    "identity:test": "npm --prefix identity-platform test",
    "identity:build": "npm run typecheck",
    "identity:openapi": "node --import tsx src/identity-platform/interfaces/openapi/export.ts",
    "identity:migrations:validate": "node --import tsx scripts/validate-identity-migrations.mjs",
    "identity:quality": "npm run identity:lint && npm run test:identity && npm run identity:migrations:validate && npm run typecheck && npm run identity:openapi",
    "identity:docker": "docker build -f Dockerfile.backend .",
    "quality": "npm run check:env && npm run typecheck && npm run lint && npm run format:check && npm run lint:architecture && npm run lint:boundaries && npm run lint:routes && npm run check:circular && npm run check:deadcode && npm run check:deps && npm run test:ci && npm run build:ci"
  },
  "dependencies": {
    "@boxicons/react": "^1.0.3",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "apexcharts": "^5.10.3",
    "bootstrap-icons": "^1.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.36.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.5",
    "postcss": "^8.5.15",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-apexcharts": "^2.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "redis": "^5.8.2",
    "react-hook-form": "^7.80.0",
    "react-simple-wysiwyg": "^3.4.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.12",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@testing-library/react": "^16.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/nodemailer": "^7.0.3",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "knip": "^5.63.1",
    "lint-staged": "^16.2.6",
    "madge": "^8.0.0",
    "pg-mem": "^3.0.5",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "tsx": "^4.20.6",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
