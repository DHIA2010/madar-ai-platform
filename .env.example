# MADAR runtime mode
# Allowed values: development | stage | production | mock
# Use `mock` to enable mock repositories/authentication explicitly.
NEXT_PUBLIC_APP_RUNTIME_MODE=development

# Core app metadata
NEXT_PUBLIC_APP_NAME=MADAR
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional for subpath hosting (example: /my-app). Leave empty for root hosting.
NEXT_PUBLIC_BASE_PATH=

# API endpoint
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:3001

# Runtime behavior
NEXT_PUBLIC_REQUEST_TIMEOUT_MS=15000
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=true
NEXT_PUBLIC_ENABLE_MOCK_REPOSITORIES=true
