# ----------------------------------------------------------------------------
# MADAR Local Development Environment (Docker Compose)
# ----------------------------------------------------------------------------

# Frontend runtime
NEXT_PUBLIC_APP_RUNTIME_MODE=development
NEXT_PUBLIC_APP_NAME=MADAR
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_REQUEST_TIMEOUT_MS=15000
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=true
NEXT_PUBLIC_ENABLE_MOCK_REPOSITORIES=false

# Server-side API runtime
APP_RUNTIME_MODE=development
API_BASE_URL=http://backend:4000
AUTH_API_BASE_URL=http://backend:4000
ENABLE_MOCK_REPOSITORIES=false
REQUEST_TIMEOUT_MS=15000

# Backend ports and identity settings
BACKEND_PORT=4000
FRONTEND_PORT=3000
IDENTITY_PLATFORM_PORT=4000
IDENTITY_PLATFORM_JWT_SECRET=dev_identity_secret_change_me_32_chars
IDENTITY_PLATFORM_TOKEN_HASH_SECRET=dev_identity_token_hash_change_me_32_chars
IDENTITY_PLATFORM_EMAIL_FROM=identity@madar.local
IDENTITY_PLATFORM_FEATURE_FLAGS={}
IDENTITY_PLATFORM_POSTGRES_MAX_CONNECTIONS=15
IDENTITY_PLATFORM_REDIS_KEY_PREFIX=madar:identity:
IDENTITY_PLATFORM_STORAGE_PATH=/workspace/.madar-identity-storage
IDENTITY_PLATFORM_N8N_BASE_URL=http://n8n:5678
IDENTITY_PLATFORM_N8N_API_BASE_URL=http://n8n:5678/api/v1
IDENTITY_PLATFORM_N8N_API_KEY=madar-local-n8n-api-key
NEXT_PUBLIC_N8N_BASE_URL=http://localhost:5678

# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=madar_n8n_encryption_key_32_chars_minimum
N8N_SECURE_COOKIE=false
N8N_PUBLIC_API_DISABLED=false
N8N_DB_TYPE=sqlite
N8N_DB_SQLITE_VACUUM_ON_STARTUP=true
N8N_TIMEZONE=UTC

# PostgreSQL
POSTGRES_DB=madar
POSTGRES_USER=madar
POSTGRES_PASSWORD=madar_password

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible local replacement)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=madar-local
MINIO_HEALTHCHECK_URL=http://minio:9000/minio/health/live
MINIO_ENDPOINT=http://minio:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=madar-local
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true

# Mailpit / SMTP
SMTP_HOST=mailpit
SMTP_PORT=1025

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@madar.local
PGADMIN_DEFAULT_PASSWORD=admin123

# Bootstrap tuning
LOCAL_BOOTSTRAP_MAX_ATTEMPTS=60
LOCAL_BOOTSTRAP_DELAY_MS=2000
