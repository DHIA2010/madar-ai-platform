domain_name                    = "madar.ai"
hosted_zone_id                 = "Z0123456789EXAMPLE"
github_repository              = "madar-platform/pulse-ui-next"
github_oidc_provider_arn       = "arn:aws:iam::123456789012:oidc-provider/token.actions.githubusercontent.com"
deployment_operator_principals = ["arn:aws:iam::123456789012:role/platform-admin"]
alarm_email_endpoints          = ["platform-alerts@madar.ai", "security-alerts@madar.ai"]

# CI should replace these with immutable tags
frontend_image = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/madar-prod/frontend:latest"
backend_image  = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/madar-prod/backend:latest"

# Inject from secret store at runtime, not committed plaintext
db_master_password = "REPLACE_ME"
